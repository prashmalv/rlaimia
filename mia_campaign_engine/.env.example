# ─── Copy this file to .env and fill in your values ──────────────────────────

# ─── Azure (fill after running infra/deploy.sh) ───────────────────────────────
AZURE_TENANT_ID=<your-tenant-id>
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_RESOURCE_GROUP=mia-campaign-rg
AZURE_STORAGE_ACCOUNT=miacampaignstore
AZURE_STORAGE_KEY=<from-azure-portal>
AZURE_STORAGE_CONN_STR=DefaultEndpointsProtocol=https;AccountName=miacampaignstore;AccountKey=<key>;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER_IMG=campaign-images
AZURE_BLOB_CONTAINER_VID=campaign-videos
AZURE_CDN_BASE_URL=

# ─── Database ─────────────────────────────────────────────────────────────────
# Local SQLite (default, no change needed):
DATABASE_URL=sqlite+aiosqlite:///./mia_campaign.db
# Azure PostgreSQL (uncomment for prod):
# DATABASE_URL=postgresql+asyncpg://miaadmin:YourPassword123@mia-campaign-db.postgres.database.azure.com/mia_campaign

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Azure Redis Cache (uncomment for prod):
# REDIS_URL=rediss://:YourAccessKey@mia-campaign-redis.redis.cache.windows.net:6380/0

# ─── Workers ─────────────────────────────────────────────────────────────────
IMAGE_WORKER_CONCURRENCY=8
VIDEO_WORKER_CONCURRENCY=4
TASK_CHUNK_SIZE=500

# ─── Video ────────────────────────────────────────────────────────────────────
VIDEO_FPS=24
VIDEO_CODEC=libx264
VIDEO_CRF=23
# For Azure GPU VM (NC series), uncomment:
# VIDEO_HWACCEL=h264_nvenc
# VIDEO_CODEC=h264_nvenc

# ─── API Security ─────────────────────────────────────────────────────────────
SECRET_KEY=<generate-with: openssl rand -hex 32>
API_TOKEN=<generate-with: openssl rand -hex 32>

# ─── Fonts (Mia Brand) ────────────────────────────────────────────────────────
FONT_GOTHAM_BOLD=assets/fonts/gotham/Gotham-Bold.otf
FONT_GOTHAM_MEDIUM=assets/fonts/gotham/Gotham-Medium.otf
FONT_GOTHAM_BOOK=assets/fonts/gotham/Gotham-Book.otf
FONT_GARAMOND_REGULAR=assets/fonts/garamond/EBGaramond-Regular.ttf
FONT_GARAMOND_BOLD=assets/fonts/garamond/EBGaramond-Bold.ttf

# ─── SAS Token TTL ────────────────────────────────────────────────────────────
SAS_TOKEN_HOURS=72

LOG_LEVEL=INFO
